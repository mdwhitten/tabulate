# Tabulate environment configuration.
# Copy to .env and fill in your values:  cp .env.example .env
#
# Format: KEY=value, one per line. No quotes, no `export`, no spaces around `=`.
# Lines starting with # are comments.

# ── Required ──────────────────────────────────────────────────────────────────
# Anthropic API key for Claude Vision receipt categorization.
ANTHROPIC_API_KEY=sk-ant-...

# ── Optional ──────────────────────────────────────────────────────────────────
# YNAB integration. Paste a YNAB Personal Access Token to sync approved receipts
# to your budget. Leave blank/unset to keep the integration disabled.
YNAB_API_TOKEN=

# Log verbosity: DEBUG | INFO | WARNING | ERROR (default: INFO).
LOG_LEVEL=INFO

# Comma-separated list of allowed CORS origins (default: * ). Set explicit
# origins if you serve the app from a fixed domain.
CORS_ORIGINS=

# DB_PATH and IMAGE_DIR are set by docker-compose.yml and only need to be
# provided here if you run the backend outside of Docker Compose.
# DB_PATH=/data/tabulate.db
# IMAGE_DIR=/data/images
